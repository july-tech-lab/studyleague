    {
      "policy_name": "View members of visible groups",
      "schema_name": "public",
      "table_name": "group_members",
      "command": "SELECT",
      "roles": "{authenticated}",
      "permissive": "PERMISSIVE",
      "using_expression": "((user_id = auth.uid()) OR (EXISTS ( SELECT 1\n   FROM groups g\n  WHERE ((g.id = group_members.group_id) AND (g.visibility = 'public'::group_visibility)))) OR (EXISTS ( SELECT 1\n   FROM groups g\n  WHERE ((g.id = group_members.group_id) AND (g.created_by = auth.uid())))))",
      "check_expression": null
    },
    {
      "policy_name": "Group admins can update memberships",
      "schema_name": "public",
      "table_name": "group_members",
      "command": "UPDATE",
      "roles": "{authenticated}",
      "permissive": "PERMISSIVE",
      "using_expression": "(EXISTS ( SELECT 1\n   FROM group_members gm\n  WHERE ((gm.group_id = group_members.group_id) AND (gm.user_id = ( SELECT auth.uid() AS uid)) AND (gm.role = 'group_admin'::group_role) AND (gm.status = 'approved'::membership_status))))",
      "check_expression": "(EXISTS ( SELECT 1\n   FROM group_members gm\n  WHERE ((gm.group_id = group_members.group_id) AND (gm.user_id = ( SELECT auth.uid() AS uid)) AND (gm.role = 'group_admin'::group_role) AND (gm.status = 'approved'::membership_status))))"
    },
    {
      "policy_name": "Group creators and admins can delete groups",
      "schema_name": "public",
      "table_name": "groups",
      "command": "DELETE",
      "roles": "{authenticated}",
      "permissive": "PERMISSIVE",
      "using_expression": "((( SELECT auth.uid() AS uid) = created_by) OR (EXISTS ( SELECT 1\n   FROM group_members gm\n  WHERE ((gm.group_id = groups.id) AND (gm.user_id = ( SELECT auth.uid() AS uid)) AND (gm.role = 'group_admin'::group_role) AND (gm.status = 'approved'::membership_status)))))",
      "check_expression": null
    },

      "check_expression": "(EXISTS ( SELECT 1\n   FROM group_members gm\n  WHERE ((gm.group_id = groups.id) AND (gm.user_id = auth.uid()) AND (gm.role = 'group_admin'::group_role) AND (gm.status = 'approved'::membership_status))))"

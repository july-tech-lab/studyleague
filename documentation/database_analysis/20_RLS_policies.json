    {
      "policy_name": "Users can read groups they belong to or public",
      "schema_name": "public",
      "table_name": "groups",
      "command": "SELECT",
      "roles": "{public}",
      "permissive": "PERMISSIVE",
      "using_expression": "((visibility = 'public'::group_visibility) OR (created_by = auth.uid()) OR (EXISTS ( SELECT 1\n   FROM group_members gm\n  WHERE ((gm.group_id = groups.id) AND (gm.user_id = auth.uid()) AND (gm.status = 'approved'::membership_status)))))",
      "check_expression": null
    },
